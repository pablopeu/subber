{
  "name": "subber",
  "private": true,
  "version": "1.2.6",
  "description": "Browser-based subtitle editor with FFmpeg burn-in export",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm run dev -w server\" \"npm run dev -w client\"",
    "build": "npm run build -w client",
    "start": "npm run start -w server",
    "fonts": "node server/scripts/fetch-fonts.mjs",
    "package:win": "node scripts/package.mjs win",
    "package:linux": "node scripts/package.mjs linux",
    "package:all": "node scripts/package.mjs win linux"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.21.0",
    "adm-zip": "^0.5.16",
    "concurrently": "^9.1.2",
    "esbuild": "^0.28.1"
  }
}
